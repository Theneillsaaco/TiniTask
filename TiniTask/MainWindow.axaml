<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:material="clr-namespace:Material.Styles.Controls;assembly=Material.Styles"
        xmlns:models="clr-namespace:TiniTask.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="600"
        x:Class="TiniTask.MainWindow"
        x:CompileBindings="False"
        Title="TiniTask">
    
    <StackPanel Margin="20" Spacing="12">
        <TextBlock Text="Mini TiniTask"
                   FontSize="24"
                   FontWeight="Bold"
                   HorizontalAlignment="Center" />
        
        <material:Card Padding="15">
            <StackPanel Spacing="10">
                <TextBox Name="TextInput" 
                         PlaceholderText="Texto a escribir" />
                
                <TextBox Name="IntervalInput" 
                         PlaceholderText="Intervalo en segundos"/>
                
                <Button Content="Agregar"
                        Click="AddTask_Click"
                        HorizontalAlignment="Right"/>
            </StackPanel>
        </material:Card>
        
        <ListBox Name="TaskList">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="models:TaskItem">
                    <material:Card Margin="0,5" Padding="10">
                        <StackPanel>
                            <TextBlock Text="{Binding Text}" 
                                       FontWeight="Bold"/>
                            
                            <TextBlock Text="{Binding Interval, StringFormat='Intervalo: {0}s'}" />
                            
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <Button Content="Iniciar" 
                                        Click="StartTask_Click"/>
                                
                                <Button Content="Detener"
                                        Click="StopTask_Click"/>
                                
                                <Button Content="Eliminar"
                                        Click="DeleteTask_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </material:Card>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        
        <TextBlock Name="StatusText"
                   Text="Estado: Listo"
                   HorizontalAlignment="Center"/>
    </StackPanel>
</Window>
